@startuml SecurityTestService
start
:Получить ApiSpec и настройки;
:Создать пустой список уязвимостей;
while (Для каждого эндпоинта в spec.Endpoints)
  :Выполнить пассивную проверку заголовков безопасности;
  :Выполнить проверку утечки PII в ответе;
  if (эндпоинт содержит параметры) then (да)
    while (Для каждого типа атаки: SQLi, XSS, PathTraversal...)
      :Получить список payload'ов (через IPayloadGenerator);
      while (Для каждого payload)
        :Сформировать вредоносный URL (подстановка);
        :Отправить запрос;
        :Проанализировать ответ;
        if (обнаружена уязвимость) then (да)
          :Создать объект Vulnerability;
          :Добавить в список;
        endif
      endwhile
    endwhile
  endif
endwhile
:Вернуть список уязвимостей;
stop
@enduml